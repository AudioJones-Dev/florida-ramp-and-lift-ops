{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://florida-ramp-and-lift-ops.local/schemas/job.schema.json",
  "title": "UniversalJob",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "client",
    "site",
    "work_order",
    "asset",
    "scope",
    "labor",
    "equipment",
    "safety",
    "billing",
    "completion"
  ],
  "properties": {
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "account_number": { "type": "string" }
      }
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["address"],
      "properties": {
        "address": {
          "type": "object",
          "additionalProperties": false,
          "required": ["full"],
          "properties": {
            "full": { "type": "string", "minLength": 1 }
          }
        },
        "contact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string", "format": "email" }
          }
        }
      }
    },
    "work_order": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number"],
      "properties": {
        "number": { "type": "string", "minLength": 1 },
        "sap_order_number": { "type": "string" },
        "source_system": { "type": "string", "default": "WillScot" }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "product_unit_number": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "summary": { "type": "string" },
        "line_items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["description", "quantity"],
            "properties": {
              "description": { "type": "string", "minLength": 1 },
              "quantity": { "type": "number", "minimum": 0 },
              "unit": { "type": "string" }
            }
          }
        },
        "dispatch_requirements": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "labor": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "crew_size": { "type": "integer", "minimum": 0 },
        "special_skills": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "equipment": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ppe_required"],
      "minProperties": 1,
      "properties": {
        "requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ppe_required": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["steel-toed boots", "safety glasses", "gloves"]
        },
        "hazards": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "billing": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "reference": { "type": "string" },
        "line_item_total": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "default": "USD" }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "signature_present"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed", "signed_off"]
        },
        "signature_present": { "type": "boolean" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
